{
    "name": "jessegall/concurrent",
    "description": "A thread-safe wrapper for cached values with locking, validation, and read-only method support",
    "keywords": ["laravel", "cache", "concurrent", "thread-safe", "locking"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jesse Gall",
            "email": "jessegall@example.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "suggest": {
        "illuminate/cache": "Required for the Laravel adapter (^10.0|^11.0|^12.0|^13.0)",
        "illuminate/support": "Required for the Laravel adapter (^10.0|^11.0|^12.0|^13.0)"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "JesseGall\\Concurrent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JesseGall\\Concurrent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JesseGall\\Concurrent\\Laravel\\ConcurrentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
